# Environment Variables for EVA DevBench

# Copy this file to .env.production for production builds
# or .env.local for local development overrides

# =============================================================================
# APIM Configuration (Required)
# =============================================================================
# Base URL for Azure APIM Gateway
# Example: https://api.esdaicoe.example.gc.ca/devbench/v1
VITE_APIM_BASE_URL=/devbench/v1

# =============================================================================
# Application Configuration (Optional)
# =============================================================================
# Enable demo mode with mock data (true/false)
VITE_DEMO_MODE_ENABLED=true

# Default language (en/fr)
VITE_DEFAULT_LANGUAGE=en

# =============================================================================
# Monitoring (Optional)
# =============================================================================
# Azure Application Insights connection string
# Get from: Azure Portal → Application Insights → Properties
# VITE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# =============================================================================
# Feature Flags (Optional)
# =============================================================================
# Enable experimental features
# VITE_ENABLE_CHAT=false
# VITE_ENABLE_GROUNDED_CHAT=false
# VITE_ENABLE_EXPORT_REPORTS=true

# =============================================================================
# Notes
# =============================================================================
# - All variables prefixed with VITE_ are embedded in the client bundle
# - Never include secrets or API keys in these variables
# - For local dev, create .env.local (gitignored)
# - For production, set in Azure Portal or GitHub Secrets
# - Changes to .env files require rebuild (npm run build)
